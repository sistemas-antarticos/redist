# ==========================================
# Configuración del Entorno y Proxy
# ==========================================
# Importante: Como se utiliza Nginx Proxy Manager Plus Plus (NPM+) con HTTPS,
# se debe definir la URL base para que Laravel genere correctamente los enlaces.
APP_URL=https://manager.sistema.lan

# ==========================================
# Configuración Base de Datos Manager
# ==========================================
DB_PASSWORD=una_contraseña_segura

# ==========================================
# Variables Opcionales
# ==========================================
# APP_ENV=production
# APP_DEBUG=false
# DB_DATABASE=sistema
# DB_USERNAME=postgres
# DB_PORT=5432
